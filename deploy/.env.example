# SquirroFlow Two-Stack Queue Mode Configuration
# Copy this file to .env and adjust values as needed.
#
# Two stacks prevent queue deadlock: orchestrator chatflows and their
# sub-chatflows run on separate worker pools.

# --- Orchestrator Stack (handles orchestrator chatflows) ---
ORCH_PORT=3000
ORCH_WORKER_PORT=5566
ORCH_QUEUE_NAME=squirroflow-orch-queue
ORCH_WORKER_CONCURRENCY=2

# --- Sub-chatflow Stack (handles leaf sub-chatflows) ---
SUB_PORT=3001
SUB_WORKER_PORT=5567
SUB_QUEUE_NAME=squirroflow-sub-queue
SUB_WORKER_CONCURRENCY=10

# --- Queue Mode ---
MODE=queue
REMOVE_ON_AGE=24
REMOVE_ON_COUNT=1000
QUEUE_REDIS_EVENT_STREAM_MAX_LEN=1000
ENABLE_BULLMQ_DASHBOARD=true

# --- Storage ---
DATABASE_PATH=/root/.flowise
BLOB_STORAGE_PATH=/root/.flowise/storage
SECRETKEY_PATH=/root/.flowise
LOG_PATH=/root/.flowise/logs

# --- PostgreSQL (recommended for production) ---
DATABASE_TYPE=postgres
DATABASE_HOST=squirroflow-postgres
DATABASE_PORT=5432
DATABASE_NAME=flowise
DATABASE_USER=flowise
DATABASE_PASSWORD=flowise

# --- Security ---
IFRAME_ORIGINS=*
CORS_ORIGINS=*
HTTP_SECURITY_CHECK=false

# --- Secrets (generate unique values for production) ---
#FLOWISE_SECRETKEY_OVERWRITE=
#EXPRESS_SESSION_SECRET=

# --- External dependencies allowed in Tool Function nodes ---
#TOOL_FUNCTION_EXTERNAL_DEP=ioredis

# --- Volume migration (reuse existing Flowise volumes) ---
# Set these to point to existing volumes when migrating from a Flowise deployment.
# Once migrated, you can remove these and let the defaults apply.
#SQUIRROFLOW_DATA_VOLUME=flowise_data
#SQUIRROFLOW_POSTGRES_VOLUME=flowise-queue_postgres_data
#SQUIRROFLOW_POSTGRES_EXTERNAL=true
